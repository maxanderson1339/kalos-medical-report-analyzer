generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  MEMBER
  COACH
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(MEMBER)
  createdAt    DateTime @default(now())
  member       Member?
}

model Member {
  id        String   @id @default(cuid())
  userId    String   @unique
  fullName  String
  goal      String?
  heightCm  Float?
  sex       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans     Scan[]
  uploads   UploadedFile[]
}

model UploadedFile {
  id          String   @id @default(cuid())
  memberId    String
  fileName    String
  fileUrl     String
  parseStatus String   @default("PENDING")
  uploadedAt  DateTime @default(now())
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Scan {
  id                String   @id @default(cuid())
  memberId          String
  scanDate          DateTime
  weightKg          Float
  bodyFatPercent    Float
  fatMassKg         Float
  leanMassKg        Float
  visceralFatMassKg Float?
  boneMassKg        Float?
  bmrKcal           Int?
  trunkFatKg        Float?
  trunkLeanMassKg   Float?
  androidFatPercent Float?
  gynoidFatPercent  Float?
  notes             String?
  createdAt         DateTime @default(now())
  member            Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, scanDate])
}